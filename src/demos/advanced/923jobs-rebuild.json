      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>9·2·3 Jobs — Work that fits your life</title>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:ital,wght@1,600;1,800&display=swap\" rel=\"stylesheet\">\n<style>\n  :root {\n    --ink: #0F172A; --ink-soft: #334155; --muted: #64748B;\n    --line: #E5E7EB; --cream: #FDF5EC;\n    --accent: #FF6B4A; --accent-deep: #E5482A;\n    --plum: #5B2E91; --mint: #0E9488;\n  }\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  html { scroll-behavior: smooth; }\n  body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; color: var(--ink); line-height: 1.6; background: #fff; }\n  a { color: inherit; text-decoration: none; }\n  .wrap { max-width: 1180px; margin: 0 auto; padding: 0 24px; }\n  .serif { font-family: 'Fraunces', Georgia, serif; font-style: italic; font-weight: 800; }\n\n  /* Nav */\n  nav.top { position: sticky; top: 0; background: rgba(255,255,255,.88); backdrop-filter: saturate(180%) blur(14px); border-bottom: 1px solid var(--line); z-index: 50; }\n  nav.top .inner { display: flex; align-items: center; gap: 32px; padding: 14px 0; }\n  .logo { font-weight: 800; font-size: 20px; letter-spacing: -.02em; }\n  .logo .b { color: var(--accent); }\n  nav.top .links { display: flex; gap: 26px; flex: 1; margin-left: 12px; }\n  nav.top .links a { font-size: 14px; color: var(--ink-soft); font-weight: 500; }\n  nav.top .links a:hover { color: var(--ink); }\n  .btn { display: inline-flex; align-items: center; gap: 6px; padding: 10px 18px; border-radius: 999px; font-size: 14px; font-weight: 600; cursor: pointer; transition: all .15s; border: 1px solid transparent; white-space: nowrap; }\n  .btn.primary { background: var(--ink); color: #fff; }\n  .btn.primary:hover { background: #000; }\n  .btn.ghost { background: transparent; color: var(--ink); border-color: var(--line); }\n  .btn.ghost:hover { border-color: var(--ink); }\n  .btn.accent { background: var(--accent); color: #fff; }\n  .btn.accent:hover { background: var(--accent-deep); }\n\n  /* Hero */\n  .hero { background: linear-gradient(180deg, var(--cream) 0%, #FFFFFF 85%); padding: 72px 0 48px; overflow: hidden; }\n  .hero-grid { display: grid; grid-template-columns: 1.15fr 1fr; gap: 56px; align-items: center; }\n  .eyebrow { display: inline-flex; align-items: center; gap: 8px; background: #FFFFFF; border: 1px solid var(--line); padding: 6px 14px; border-radius: 999px; font-size: 12px; font-weight: 600; color: var(--plum); margin-bottom: 22px; }\n  .eyebrow .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }\n  .hero h1 { font-size: 64px; font-weight: 800; line-height: 1.02; letter-spacing: -.03em; margin-bottom: 22px; }\n  .hero h1 .glow { background: linear-gradient(135deg, var(--accent) 0%, var(--plum) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }\n  .hero p.lede { font-size: 19px; color: var(--ink-soft); max-width: 520px; margin-bottom: 30px; }\n  .hero .ctas { display: flex; gap: 10px; margin-bottom: 36px; flex-wrap: wrap; }\n  .trust { display: flex; gap: 36px; flex-wrap: wrap; }\n  .trust .item .num { font-size: 24px; font-weight: 800; display: block; }\n  .trust .item .lbl { font-size: 13px; color: var(--muted); }\n\n  /* Search card */\n  .search-card { background: #fff; border: 1px solid var(--line); border-radius: 20px; padding: 10px; box-shadow: 0 20px 60px -20px rgba(15,23,42,.15); }\n  .search-row { display: grid; grid-template-columns: 1.5fr 1fr 1fr auto; }\n  .search-row .field { padding: 12px 14px; border-right: 1px solid var(--line); }\n  .search-row .field:last-of-type { border-right: none; }\n  .search-row .field .lbl { font-size: 11px; text-transform: uppercase; letter-spacing: .08em; color: var(--muted); font-weight: 600; margin-bottom: 2px; }\n  .search-row .field .val { font-size: 14px; color: var(--ink); font-weight: 500; display: flex; align-items: center; gap: 6px; }\n  .search-row .field .val svg { opacity: .5; }\n  .search-row button { margin: 6px; padding: 14px 22px; border-radius: 14px; background: var(--accent); color: #fff; font-weight: 600; border: none; cursor: pointer; font-size: 14px; }\n  .search-card .tags { display: flex; gap: 8px; padding: 14px 6px 6px; flex-wrap: wrap; }\n  .tag-btn { font-size: 12px; color: var(--ink-soft); background: #F1F5F9; padding: 6px 12px; border-radius: 999px; cursor: pointer; border: none; font-weight: 500; }\n  .tag-btn:hover { background: #E2E8F0; }\n\n  /* Section */\n  .section { padding: 88px 0; }\n  .section-head { display: flex; align-items: end; justify-content: space-between; margin-bottom: 40px; gap: 24px; flex-wrap: wrap; }\n  .section-head h2 { font-size: 40px; font-weight: 800; letter-spacing: -.02em; line-height: 1.1; }\n  .section-head p { color: var(--muted); max-width: 480px; margin-top: 8px; font-size: 16px; }\n  .section-head .view-all { font-size: 14px; font-weight: 600; color: var(--accent); }\n\n  /* Jobs */\n  .jobs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }\n  .job { background: #fff; border: 1px solid var(--line); border-radius: 18px; padding: 22px; transition: all .18s ease; cursor: pointer; display: flex; flex-direction: column; gap: 12px; }\n  .job:hover { border-color: var(--accent); transform: translateY(-3px); box-shadow: 0 18px 40px -18px rgba(255,107,74,.35); }\n  .job .head { display: flex; justify-content: space-between; align-items: start; gap: 12px; }\n  .job .company { font-size: 13px; color: var(--muted); font-weight: 500; margin-bottom: 2px; }\n  .job .tag-row { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 4px; }\n  .tag { font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 999px; letter-spacing: .01em; }\n  .tag.part { background: #FEF0E7; color: #BE4A20; }\n  .tag.hybrid { background: #ECFDF5; color: #047857; }\n  .tag.frac { background: #F3E8FF; color: #6B21A8; }\n  .tag.remote { background: #EFF6FF; color: #1D4ED8; }\n  .tag.fourday { background: #FFFBEB; color: #92400E; }\n  .job h3 { font-size: 17px; font-weight: 700; line-height: 1.3; }\n  .job .meta { display: flex; flex-direction: column; gap: 7px; font-size: 13px; color: var(--ink-soft); margin-top: auto; padding-top: 14px; border-top: 1px solid var(--line); }\n  .job .meta .row { display: flex; align-items: center; gap: 8px; }\n  .job .save { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--line); color: var(--muted); flex-shrink: 0; background: #fff; cursor: pointer; }\n  .job .save:hover { color: var(--accent); border-color: var(--accent); }\n\n  /* Testimonials */\n  .testimonials { background: var(--cream); padding: 80px 0; }\n  .quotes { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }\n  .quote { background: #fff; border-radius: 18px; padding: 28px; border: 1px solid rgba(255,107,74,.15); }\n  .stars { color: var(--accent); font-size: 14px; letter-spacing: 2px; margin-bottom: 10px; }\n  .quote p { font-size: 15.5px; line-height: 1.6; color: var(--ink); margin-bottom: 20px; }\n  .quote .who { display: flex; align-items: center; gap: 12px; }\n  .avatar { width: 42px; height: 42px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), var(--plum)); display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 13px; }\n  .who .name { font-weight: 600; font-size: 14px; line-height: 1.2; }\n  .who .role { font-size: 12px; color: var(--muted); }\n\n  /* Business */\n  .business { background: var(--ink); color: #fff; padding: 88px 0; position: relative; overflow: hidden; }\n  .business::before { content: \"\"; position: absolute; right: -250px; top: -150px; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(255,107,74,.28) 0%, transparent 65%); }\n  .business-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 56px; align-items: center; position: relative; z-index: 1; }\n  .business h2 { font-size: 44px; font-weight: 800; letter-spacing: -.02em; margin-bottom: 18px; line-height: 1.1; }\n  .business p.lede { font-size: 18px; color: #CBD5E1; margin-bottom: 28px; max-width: 520px; }\n  .biz-feats { display: flex; flex-direction: column; gap: 14px; margin-bottom: 30px; }\n  .biz-feat { display: flex; gap: 12px; align-items: start; font-size: 15px; color: #E2E8F0; }\n  .check { width: 22px; height: 22px; border-radius: 50%; background: var(--accent); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 12px; flex-shrink: 0; margin-top: 2px; font-weight: 700; }\n  .stat-card { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1); border-radius: 20px; padding: 32px; }\n  .stat-card h4 { font-size: 13px; color: #94A3B8; font-weight: 500; margin-bottom: 6px; text-transform: uppercase; letter-spacing: .08em; }\n  .stat-card .big { font-size: 52px; font-weight: 800; letter-spacing: -.03em; line-height: 1; }\n  .stat-card .big .a { color: var(--accent); }\n  .stat-card .note { font-size: 13px; color: #94A3B8; margin-top: 8px; }\n  .stat-card hr { border: none; border-top: 1px solid rgba(255,255,255,.1); margin: 24px 0; }\n\n  /* Founder */\n  .founder { padding: 88px 0; background: linear-gradient(180deg, #fff 0%, var(--cream) 100%); }\n  .founder-grid { display: grid; grid-template-columns: 1fr 1.3fr; gap: 56px; align-items: center; }\n  .founder-photo { aspect-ratio: 4/5; border-radius: 24px; background: linear-gradient(135deg, #FFB89F 0%, var(--accent) 50%, var(--plum) 100%); position: relative; overflow: hidden; }\n  .founder-photo::after { content: \"HW\"; font-size: 180px; font-weight: 800; color: rgba(255,255,255,.28); position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); letter-spacing: -.05em; font-family: 'Fraunces', serif; }\n  .founder-photo .badge { position: absolute; bottom: 20px; left: 20px; background: rgba(255,255,255,.95); padding: 10px 14px; border-radius: 12px; font-size: 12px; font-weight: 600; color: var(--ink); display: flex; align-items: center; gap: 8px; }\n  .founder-photo .badge::before { content: \"★\"; color: var(--accent); }\n  .founder .eyebrow-b { font-size: 12px; text-transform: uppercase; letter-spacing: .12em; font-weight: 700; color: var(--plum); margin-bottom: 14px; }\n  .founder h2 { font-size: 36px; font-weight: 800; letter-spacing: -.02em; margin-bottom: 18px; line-height: 1.15; }\n  .founder blockquote { font-size: 20px; line-height: 1.5; color: var(--ink-soft); border-left: 3px solid var(--accent); padding-left: 20px; margin-bottom: 24px; }\n  .awards { display: flex; gap: 22px; margin-top: 24px; flex-wrap: wrap; }\n  .award { display: flex; align-items: center; gap: 10px; font-size: 13px; color: var(--muted); font-weight: 500; }\n  .award .badge { width: 36px; height: 36px; border-radius: 50%; background: #fff; border: 2px solid var(--accent); color: var(--accent); display: flex; align-items: center; justify-content: center; font-size: 15px; font-weight: 800; }\n\n  /* Newsletter */\n  .newsletter { background: var(--cream); padding: 48px 0; border-top: 1px solid rgba(255,107,74,.15); }\n  .news-box { display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap; }\n  .news-box h3 { font-size: 26px; font-weight: 800; letter-spacing: -.02em; }\n  .news-box p { font-size: 14px; color: var(--muted); margin-top: 4px; }\n  .news-form { display: flex; gap: 8px; min-width: 380px; }\n  .news-form input { flex: 1; padding: 14px 20px; border-radius: 999px; border: 1px solid var(--line); background: #fff; font-size: 14px; font-family: inherit; }\n  .news-form input:focus { outline: none; border-color: var(--accent); }\n\n  /* Footer */\n  footer { background: var(--ink); color: #94A3B8; padding: 60px 0 24px; }\n  .foot-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; padding-bottom: 40px; border-bottom: 1px solid rgba(255,255,255,.1); margin-bottom: 24px; }\n  footer .logo { color: #fff; font-size: 22px; margin-bottom: 16px; display: inline-block; }\n  footer p.about { font-size: 14px; line-height: 1.7; max-width: 360px; margin-bottom: 20px; }\n  footer h5 { color: #fff; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; margin-bottom: 16px; }\n  footer ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }\n  footer ul a { font-size: 14px; color: #94A3B8; }\n  footer ul a:hover { color: #fff; }\n  .socials { display: flex; gap: 10px; }\n  .socials a { width: 38px; height: 38px; border-radius: 50%; background: rgba(255,255,255,.06); display: flex; align-items: center; justify-content: center; color: #fff; transition: background .15s; }\n  .socials a:hover { background: var(--accent); }\n  .foot-bottom { display: flex; justify-content: space-between; align-items: center; font-size: 13px; flex-wrap: wrap; gap: 12px; }\n\n  @media (max-width: 900px) {\n    .hero-grid, .business-grid, .founder-grid { grid-template-columns: 1fr; gap: 32px; }\n    .jobs-grid, .quotes, .foot-grid { grid-template-columns: 1fr; }\n    .hero h1 { font-size: 42px; }\n    .section, .business, .founder, .testimonials { padding: 56px 0; }\n    nav.top .links { display: none; }\n    .search-row { grid-template-columns: 1fr; }\n    .search-row .field { border-right: none; border-bottom: 1px solid var(--line); }\n    .search-row button { margin: 10px; }\n    .business h2 { font-size: 32px; }\n  }\n</style>\n</head>\n<body>\n\n<nav class=\"top\">\n  <div class=\"wrap inner\">\n    <div class=\"logo\">9<span class=\"b\">·</span>2<span class=\"b\">·</span>3 <span style=\"font-weight:500;color:#64748B;margin-left:2px;\">Jobs</span></div>\n    <div class=\"links\">\n      <a href=\"#jobs\">Browse jobs</a>\n      <a href=\"#business\">For employers</a>\n      <a href=\"#founder\">About</a>\n      <a href=\"#flex\">Flexible working</a>\n      <a href=\"#stories\">Stories</a>\n    </div>\n    <a class=\"btn ghost\" href=\"#signup\">Sign in</a>\n    <a class=\"btn primary\" href=\"#register\">Register CV</a>\n  </div>\n</nav>\n\n<section class=\"hero\">\n  <div class=\"wrap hero-grid\">\n    <div>\n      <span class=\"eyebrow\"><span class=\"dot\"></span> Award-winning · Women-founded · UK-wide</span>\n      <h1>Work that <span class=\"serif glow\">fits your life.</span></h1>\n      <p class=\"lede\">The UK's leading recruitment consultancy for part-time, hybrid and fractional roles. We match senior professionals with companies who've moved beyond 9-to-5.</p>\n      <div class=\"ctas\">\n        <a class=\"btn accent\" href=\"#jobs\">Browse 248 open roles →</a>\n        <a class=\"btn ghost\" href=\"#business\">I'm hiring</a>\n      </div>\n      <div class=\"trust\">\n        <div class=\"item\"><span class=\"num\">2,400+</span><span class=\"lbl\">placements made</span></div>\n        <div class=\"item\"><span class=\"num\">96%</span><span class=\"lbl\">12-month retention</span></div>\n        <div class=\"item\"><span class=\"num\">£65k</span><span class=\"lbl\">avg. FTE salary</span></div>\n      </div>\n    </div>\n    <div class=\"search-card\">\n      <div class=\"search-row\">\n        <div class=\"field\">\n          <div class=\"lbl\">Role or keyword</div>\n          <div class=\"val\">Marketing Director</div>\n        </div>\n        <div class=\"field\">\n          <div class=\"lbl\">Working pattern</div>\n          <div class=\"val\">3 days / week</div>\n        </div>\n        <div class=\"field\">\n          <div class=\"lbl\">Location</div>\n          <div class=\"val\">London · Hybrid</div>\n        </div>\n        <button>Search</button>\n      </div>\n      <div class=\"tags\">\n        <button class=\"tag-btn\">Fractional CFO</button>\n        <button class=\"tag-btn\">Part-time HR</button>\n        <button class=\"tag-btn\">4-day week</button>\n        <button class=\"tag-btn\">Fully remote</button>\n        <button class=\"tag-btn\">School hours</button>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"section\" id=\"jobs\">\n  <div class=\"wrap\">\n    <div class=\"section-head\">\n      <div>\n        <h2>Fresh roles this week</h2>\n        <p>Every role on this page is genuinely flexible — vetted by our team, with working patterns agreed up front.</p>\n      </div>\n      <a class=\"view-all\" href=\"#\">View all 248 →</a>\n    </div>\n    <div class=\"jobs-grid\">\n\n      <article class=\"job\">\n        <div class=\"head\">\n          <div>\n            <div class=\"company\">Monzo</div>\n            <div class=\"tag-row\"><span class=\"tag part\">Part-time</span><span class=\"tag hybrid\">Hybrid</span></div>\n          </div>\n          <button class=\"save\" aria-label=\"Save\">♡</button>\n        </div>\n        <h3>Senior Product Marketing Manager</h3>\n        <div class=\"meta\">\n          <div class=\"row\">💷 £72k–£85k pro rata · 3 days/week</div>\n          <div class=\"row\">📍 London · 2 days in office</div>\n          <div class=\"row\">🕐 Posted 2 days ago</div>\n        </div>\n      </article>\n\n      <article class=\"job\">\n        <div class=\"head\">\n          <div>\n            <div class=\"company\">Greenway Renewables</div>\n            <div class=\"tag-row\"><span class=\"tag frac\">Fractional</span></div>\n          </div>\n          <button class=\"save\" aria-label=\"Save\">♡</button>\n        </div>\n        <h3>Fractional Finance Director</h3>\n        <div class=\"meta\">\n          <div class=\"row\">💷 £650/day · 2 days/week</div>\n          <div class=\"row\">📍 Bristol · Hybrid</div>\n          <div class=\"row\">🕐 Posted 4 days ago</div>\n        </div>\n      </article>\n\n      <article class=\"job\">\n        <div class=\"head\">\n          <div>\n            <div class=\"company\">Olio</div>\n            <div class=\"tag-row\"><span class=\"tag part\">Part-time</span><span class=\"tag remote\">Remote</span></div>\n          </div>\n          <button class=\"save\" aria-label=\"Save\">♡</button>\n        </div>\n        <h3>Head of People</h3>\n        <div class=\"meta\">\n          <div class=\"row\">💷 £78k pro rata · 4 days/week</div>\n          <div class=\"row\">📍 Fully remote (UK)</div>\n          <div class=\"row\">🕐 Posted 1 day ago</div>\n        </div>\n      </article>\n\n      <article class=\"job\">\n        <div class=\"head\">\n          <div>\n            <div class=\"company\">Beanstalk Labs</div>\n            <div class=\"tag-row\"><span class=\"tag frac\">Fractional</span><span class=\"tag fourday\">4-day week</span></div>\n          </div>\n          <button class=\"save\" aria-label=\"Save\">♡</button>\n        </div>\n        <h3>Fractional CTO</h3>\n        <div class=\"meta\">\n          <div class=\"row\">💷 £800–£950/day · 2–3 days/week</div>\n          <div class=\"row\">📍 Manchester · Hybrid</div>\n          <div class=\"row\">🕐 Posted today</div>\n        </div>\n      </article>\n\n      <article class=\"job\">\n        <div class=\"head\">\n          <div>\n            <div class=\"company\">Patch Plants</div>\n            <div class=\"tag-row\"><span class=\"tag part\">Part-time</span><span class=\"tag hybrid\">Hybrid</span></div>\n          </div>\n          <button class=\"save\" aria-label=\"Save\">♡</button>\n        </div>\n        <h3>Senior UX Researcher</h3>\n        <div class=\"meta\">\n          <div class=\"row\">💷 £58k–£68k pro rata · School hours</div>\n          <div class=\"row\">📍 London · 1 day in office</div>\n          <div class=\"row\">🕐 Posted 3 days ago</div>\n        </div>\n      </article>\n\n      <article class=\"job\">\n        <div class=\"head\">\n          <div>\n            <div class=\"company\">Tidemark Studio</div>\n            <div class=\"tag-row\"><span class=\"tag frac\">Fractional</span><span class=\"tag remote\">Remote</span></div>\n          </div>\n          <button class=\"save\" aria-label=\"Save\">♡</button>\n        </div>\n        <h3>Fractional Head of Marketing</h3>\n        <div class=\"meta\">\n          <div class=\"row\">💷 £550/day · 2 days/week</div>\n          <div class=\"row\">📍 Fully remote (UK)</div>\n          <div class=\"row\">🕐 Posted 5 days ago</div>\n        </div>\n      </article>\n\n    </div>\n  </div>\n</section>\n\n<section class=\"testimonials\" id=\"stories\">\n  <div class=\"wrap\">\n    <div class=\"section-head\">\n      <div>\n        <h2>What people say about us</h2>\n        <p>We've placed people into roles they thought didn't exist — and helped companies discover talent they'd have missed otherwise.</p>\n      </div>\n    </div>\n    <div class=\"quotes\">\n      <div class=\"quote\">\n        <div class=\"stars\">★★★★★</div>\n        <p>\"After maternity leave I was convinced I'd have to choose between senior work and seeing my kids. Helen's team matched me with a three-day Head of Product role in four weeks. Still here two years on.\"</p>\n        <div class=\"who\">\n          <div class=\"avatar\">NS</div>\n          <div><div class=\"name\">Naomi S.</div><div class=\"role\">Head of Product · Fintech</div></div>\n        </div>\n      </div>\n      <div class=\"quote\">\n        <div class=\"stars\">★★★★★</div>\n        <p>\"We needed a fractional CFO but everyone we spoke to tried to sell us a full-timer. 9·2·3 actually understood what 'two days a week' means, and sent us three excellent candidates in a fortnight.\"</p>\n        <div class=\"who\">\n          <div class=\"avatar\">MT</div>\n          <div><div class=\"name\">Mark T.</div><div class=\"role\">CEO · Greenway Renewables</div></div>\n        </div>\n      </div>\n      <div class=\"quote\">\n        <div class=\"stars\">★★★★★</div>\n        <p>\"The shortlists are tight, the candidates are sharp, and the comms are human. The opposite of every generic recruiter we'd been burned by before.\"</p>\n        <div class=\"who\">\n          <div class=\"avatar\">RK</div>\n          <div><div class=\"name\">Rachel K.</div><div class=\"role\">People Director · Olio</div></div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"business\" id=\"business\">\n  <div class=\"wrap business-grid\">\n    <div>\n      <span class=\"eyebrow\" style=\"background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.1);color:#FDBA74;\"><span class=\"dot\"></span> For employers</span>\n      <h2>The best senior talent isn't looking full-time any more.</h2>\n      <p class=\"lede\">We specialise in the 40% of professionals who want flexibility — and won't apply to roles that don't offer it. If your next hire should be part-time, hybrid, or fractional, we'll find them in days, not months.</p>\n      <div class=\"biz-feats\">\n        <div class=\"biz-feat\"><span class=\"check\">✓</span>Shortlists of 3–5 vetted candidates within 10 working days</div>\n        <div class=\"biz-feat\"><span class=\"check\">✓</span>15% placement fee · 90-day retention guarantee</div>\n        <div class=\"biz-feat\"><span class=\"check\">✓</span>Flexibility audits — we help you structure the role properly</div>\n        <div class=\"biz-feat\"><span class=\"check\">✓</span>Diverse shortlists: 68% of our placements are women</div>\n      </div>\n      <a class=\"btn accent\" href=\"#brief\">Send us a brief →</a>\n    </div>\n    <div class=\"stat-card\">\n      <h4>Average time to shortlist</h4>\n      <div class=\"big\"><span class=\"a\">8</span> days</div>\n      <div class=\"note\">vs. industry average of 6 weeks</div>\n      <hr />\n      <h4>Placement retention</h4>\n      <div class=\"big\"><span class=\"a\">96%</span></div>\n      <div class=\"note\">still in role after 12 months</div>\n      <hr />\n      <h4>Salary range</h4>\n      <div class=\"big\">£40k – £180k</div>\n      <div class=\"note\">FTE equivalent across sectors</div>\n    </div>\n  </div>\n</section>\n\n<section class=\"founder\" id=\"founder\">\n  <div class=\"wrap founder-grid\">\n    <div class=\"founder-photo\">\n      <div class=\"badge\">Recruiter of the Year · 2024</div>\n    </div>\n    <div>\n      <div class=\"eyebrow-b\">Founder's note</div>\n      <h2>We started 9·2·3 because the old model was broken.</h2>\n      <blockquote>\"Brilliant people were leaving their careers — not because they'd stopped being brilliant, but because nobody would offer them work that fit around the rest of their lives. We built the firm they wish had existed.\"</blockquote>\n      <p style=\"color:var(--ink-soft);font-size:16px;margin-bottom:20px;\">— <strong>Helen Wright</strong>, Founder &amp; Director</p>\n      <div class=\"awards\">\n        <div class=\"award\"><span class=\"badge\">★</span>Great British Entrepreneur · 2023</div>\n        <div class=\"award\"><span class=\"badge\">♛</span>Women in Business Awards · 2024</div>\n        <div class=\"award\"><span class=\"badge\">F</span>Flexa Top 100 Employer · 2025</div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"newsletter\" id=\"flex\">\n  <div class=\"wrap news-box\">\n    <div>\n      <h3>New roles, every Monday.</h3>\n      <p>Hand-picked flexible jobs in your inbox. No spam, no recruiter clickbait.</p>\n    </div>\n    <form class=\"news-form\" onsubmit=\"event.preventDefault();this.querySelector('input').value='Thanks — you\\'re on the list.';\">\n      <input type=\"email\" placeholder=\"you@work.com\" required />\n      <button class=\"btn accent\" type=\"submit\">Subscribe</button>\n    </form>\n  </div>\n</section>\n\n<footer>\n  <div class=\"wrap\">\n    <div class=\"foot-grid\">\n      <div>\n        <div class=\"logo\">9<span style=\"color:var(--accent);\">·</span>2<span style=\"color:var(--accent);\">·</span>3 Jobs</div>\n        <p class=\"about\">An award-winning recruitment consultancy passionate about breaking the conventions of the traditional 9-to-5. UK-based, women-founded.</p>\n        <div class=\"socials\">\n          <a href=\"https://www.linkedin.com/company/10661519\" aria-label=\"LinkedIn\">in</a>\n          <a href=\"https://www.instagram.com/923jobs\" aria-label=\"Instagram\">◉</a>\n          <a href=\"https://www.facebook.com/923jobs\" aria-label=\"Facebook\">f</a>\n          <a href=\"mailto:helen@923jobs.com\" aria-label=\"Email\">✉</a>\n        </div>\n      </div>\n      <div>\n        <h5>For candidates</h5>\n        <ul>\n          <li><a href=\"#\">Browse jobs</a></li>\n          <li><a href=\"#\">Register CV</a></li>\n          <li><a href=\"#\">Flexible working guide</a></li>\n          <li><a href=\"#\">Salary benchmarks</a></li>\n        </ul>\n      </div>\n      <div>\n        <h5>For employers</h5>\n        <ul>\n          <li><a href=\"#\">Send a brief</a></li>\n          <li><a href=\"#\">How we work</a></li>\n          <li><a href=\"#\">Pricing</a></li>\n          <li><a href=\"#\">Diversity report</a></li>\n        </ul>\n      </div>\n      <div>\n        <h5>Company</h5>\n        <ul>\n          <li><a href=\"#\">Our story</a></li>\n          <li><a href=\"#\">Meet the team</a></li>\n          <li><a href=\"#\">Press &amp; awards</a></li>\n          <li><a href=\"#\">Contact</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"foot-bottom\">\n      <span>© 2026 9·2·3 Jobs Ltd. Registered in England &amp; Wales.</span>\n      <span><a href=\"#\" style=\"margin-right:16px;\">Privacy</a><a href=\"#\" style=\"margin-right:16px;\">Cookies</a><a href=\"#\">Anti-harassment policy</a></span>\n    </div>\n  </div>\n</footer>\n\n</body>\n</html>\n"
